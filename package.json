{
  "name": "react-native-template-ultimacode",
  "version": "1.0.3",
  "bin": "./bin/cli.js",
  "description": "React Native + Expo template with Zustand, React Query, React Navigation, i18n and more",
  "keywords": [
    "react-native",
    "template",
    "expo",
    "typescript",
    "zustand",
    "react-query",
    "react-navigation",
    "i18n"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aragabz/react-native-template-ultimacode.git"
  },
  "homepage": "https://github.com/aragabz/react-native-template-ultimacode#readme",
  "bugs": {
    "url": "https://github.com/aragabz/react-native-template-ultimacode/issues"
  },
  "scripts": {
    "android": "NODE_ENV=development react-native run-android",
    "ios": "NODE_ENV=development react-native run-ios",
    "lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{js,jsx,ts,tsx}' --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{js,jsx,ts,tsx,json,md,yml,yaml}'",
    "format:check": "prettier --check 'src/**/*.{js,jsx,ts,tsx,json,md,yml,yaml}'",
    "start": "NODE_ENV=development react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "link": "adb reverse tcp:8081 tcp:8081",
    "eslint:quiet": "eslint 'src/**/*.{ts,tsx}' --quiet"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{ts,tsx}": [
      "bash -c 'yarn typecheck'"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@legendapp/list": "^3.3.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native/new-app-screen": "0.86.0",
    "@react-navigation/bottom-tabs": "^7.18.4",
    "@react-navigation/native": "^7.3.5",
    "@react-navigation/native-stack": "^7.17.7",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "expo": "57.0.1",
    "expo-constants": "57.0.2",
    "expo-device": "57.0.0",
    "expo-font": "57.0.0",
    "expo-image": "57.0.0",
    "expo-local-authentication": "57.0.0",
    "expo-localization": "57.0.0",
    "expo-modules-autolinking": "57.0.3",
    "expo-notifications": "57.0.2",
    "expo-secure-store": "57.0.0",
    "expo-splash-screen": "57.0.1",
    "expo-status-bar": "57.0.0",
    "i18next": "^26.3.4",
    "react": "19.2.7",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "3.0.2",
    "react-native-mmkv": "^4.3.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "15.15.5",
    "react-native-worklets": "0.10.1",
    "react-refresh": "^0.18.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@react-native-community/cli": "20.2.0",
    "@react-native-community/cli-platform-android": "20.2.0",
    "@react-native-community/cli-platform-ios": "20.2.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@react-native/js-polyfills": "^0.86.0",
    "@react-native/metro-babel-transformer": "^0.86.0",
    "@react-native/metro-config": "^0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-refresh": "^0.14.7",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~57.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-plugin-import": "^2.32.0",
    "expo-modules-core": "^57.0.1",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "metro-config": "^0.85.0",
    "metro-runtime": "^0.85.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.9.4",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.2.7",
    "test-renderer": "^1.2.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
