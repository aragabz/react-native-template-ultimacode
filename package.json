{
  "name": "ReactNativeTemplate",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "NODE_ENV=development react-native run-android",
    "ios": "NODE_ENV=development react-native run-ios",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=development react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{ts,tsx}": [
      "bash -c 'yarn typecheck'"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native/new-app-screen": "0.85.3",
    "@react-navigation/bottom-tabs": "^7.18.2",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.18.0",
    "expo": "~56.0.12",
    "expo-constants": "^56.0.18",
    "expo-font": "^56.0.7",
    "expo-modules-autolinking": "^56.0.16",
    "expo-secure-store": "^56.0.4",
    "expo-splash-screen": "^56.0.10",
    "expo-status-bar": "^56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "15.15.5",
    "react-refresh": "^0.18.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "^0.86.0",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "^25.9.4",
    "@types/react": "19.2.17",
    "@types/react-refresh": "^0.14.7",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~56.0.0",
    "dotenv": "^17.4.2",
    "eslint": "8.57.1",
    "expo-modules-core": "^56.0.12",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "lint-staged": "^17.0.7",
    "prettier": "3.8.4",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.2.3",
    "test-renderer": "^1.2.0",
    "typescript": "^6.0.3"
